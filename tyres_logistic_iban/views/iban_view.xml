<?xml version="1.0"?>
<openerp>
    <data>
        <record id="res_country_iban_view_tree" model="ir.ui.view">
            <field name="name">res.country.iban.view.tree</field>
            <field name="model">res.country</field>
            <field name="priority" eval="40"/>
            <field name="arch" type="xml">
                <tree string="Nazioni" colors="blue: iban_management == True">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="iban_management"/>
                    <field name="iban_field" />
                </tree>
            </field>
        </record>
        <record id="res_country_iban_view_form" model="ir.ui.view">
            <field name="name">res.country.iban.view.form</field>
            <field name="model">res.country</field>
            <field name="priority" eval="40"/>
            <field name="arch" type="xml">
                <form string="Nazioni">
                    <sheet>
                         <group colspan="4" col="4">
                            <field name="code" readonly="1"/>
                            <field name="name" readonly="1"/>

                             <field name="iban_management" widget="boolean_toggle"/>
                         </group>
                         <group colspan="4" col="4" attrs="{'invisible': [('iban_management', '=', False)]}">
                             <field name="iban_format" colspan="4" />
                             <field name="iban_field" colspan="4" />
                             <field name="iban_check" colspan="4" />
                         </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="res_partner_iban_action" model="ir.actions.act_window">
            <field name="name">Nazioni per IBAN</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.country</field>
            <field name="view_mode">tree,form</field>
            <field name="view_type">form</field>
            <field name="view_id" ref="res_country_iban_view_tree"/>
            <field name="context">{'form_view_ref': 'tyres_logistic_iban.res_country_iban_view_form'}</field>
        </record>

         <!--<record model="ir.ui.view" id="view_account_fiscal_position_iban_management_form">
