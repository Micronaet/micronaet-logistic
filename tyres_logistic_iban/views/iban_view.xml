<?xml version="1.0"?>
<openerp>
    <data>
         <record model="ir.ui.view" id="view_account_fiscal_position_iban_management_form">
             <field name="name">account.fiscal.position.iban.management.form</field>
             <field name="model">account.fiscal.position</field>
             <field name="inherit_id" ref="account.view_account_position_form"/>
             <field name="arch" type="xml">
                 <page name="tax_mapping" position="after">
                     <page name="iban_page" string="IBAN">
                         <group colspan="4" col="4">
                             <field name="iban_management" />
                         </group>
                         <group colspan="4" col="4" attrs="{'invisible': [('iban_management', '=', False)]}">
                             <field name="iban_format" colspan="4" />
                             <field name="iban_field" colspan="4" />
                             <field name="iban_check" colspan="4" />
                         </group>
                     </page>
                 </page>
             </field>
         </record>
    </data>
</openerp>

