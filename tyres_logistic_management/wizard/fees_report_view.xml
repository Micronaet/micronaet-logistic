<?xml version="1.0"?>
<openerp>
    <data>
        <!-- Fees API header -->
        <record id="view_logistic_fees_api_tree" model="ir.ui.view">
            <name>logistic.fees.api.tree</name>
            <model>logistic.fees.api</model>
            <arch type="xml">
                <tree string="Documenti API Fees" colors="red: error == True">
                    <field name="date" />
                    <field name="team_id" />
                    <field name="payment_code" />
                    <field name="account_ref" />
                    <field name="error" />
                    <field name="state" />
                </tree>
            </arch>
        </record>
        <record id="view_logistic_fees_api_form" model="ir.ui.view">
            <name>logistic.fees.api.form</name>
            <model>logistic.fees.api</model>
            <arch type="xml">
                <form string="Documento API Fees">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done,manual"/>
                    </header>
                    <sheet>
                        <div class="alert alert-danger text-center o_form_header" role="status" attrs="{'invisible': [('error', '=', False)]}">
                            <strong>Attenzione!</strong> Si è verificato un errore durante la sincronizzazione o il controllo delle date extra.
                        </div>

                        <div class="oe_title">
                            <h1>
                                <field name="account_ref" placeholder="Rif. scontrino" readonly="1"/>
                            </h1>
                        </div>

                        <notebook colspan="4">
                            <page string="Dettaglio" name="page_detail">
                                <group>
                                    <group string="Dati Principali">
                                        <field name="date" readonly="1"/>
                                        <field name="team_id" readonly="1"/>
                                        <field name="payment_code" readonly="1"/>
                                    </group>
                                    <group string="Stato &amp; Sincronizzazione">
                                        <field name="account_date" readonly="1"/>
                                        <field name="force_account_ref" readonly="1"/>
                                        <field name="error" readonly="1" widget="boolean_toggle"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Note &amp; Controlli" name="page_note">
                                <group>
                                    <field name="extra_date" readonly="1"/>
                                </group>
                            </page>
                            <page string="Risposta JSON" name="page_json" attrs="{'invisible': [('json_reply', '=', False)]}">
                                <group>
                                    <field name="json_reply" readonly="1" />
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </arch>
        </record>
        <record id="view_logistic_fees_api_search" model="ir.ui.view">
            <name>logistic.fees.api.search</name>
            <model>logistic.fees.api</model>
            <arch type="xml">
                <search string="Ricerca Scontrini">
                    <field name="account_ref" string="Riferimento Scontrino"/>
                    <field name="team_id" string="Canale di Vendita"/>
                    <field name="payment_code" string="Codice Pagamento"/>
                    <field name="date" string="Data"/>

                    <filter string="Da Sincronizzare" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Sincronizzati" name="filter_done" domain="[('state', '=', 'done')]"/>

                    <separator/>
                    <filter string="Con Errore" name="filter_error" domain="[('error', '=', True)]"/>

                    <group expand="0" string="Raggruppa per">
                        <filter string="Canale" name="group_by_team" context="{'group_by': 'team_id'}"/>
                        <filter string="Pagamento" name="group_by_payment" context="{'group_by': 'payment_code'}"/>
                        <filter string="Giorno" name="group_by_date" context="{'group_by': 'date:day'}"/>
                        <filter string="Mese" name="group_by_date" context="{'group_by': 'date:month'}"/>
                        <filter string="Stato" name="group_by_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </arch>
        </record>
        <record id="action_logistic_fees_api" model="ir.actions.act_window">
            <name>Documenti API Fees</name>
            <res_model>logistic.fees.api</res_model>
            <view_type>form</view_type>
            <view_mode>tree,form</view_mode>
            <search_view_id ref="view_logistic_fees_api_search"/>
        </record>

        <!-- WIZARD -->
        <record id="view_logistic_fees_extract_wizard" model="ir.ui.view">
            <field name="name">Fees extract wizard</field>
            <field name="model">logistic.fees.extract.wizard</field>
            <field name="arch" type="xml">
              <form string="Logistic operation management:">
                  <header>
                      <button string="Cancel" class="btn-default" special="cancel" />

                      <button name="fees_report_button" string="Print report" type="object" class="btn-primary" colspan="1" icon="fa-file-text-o fa-2x"/>

                      <button name="fees_extract_button" string="Extract fees" type="object" colspan="1"
                              groups="tyres_logistic_management.group_logistic_fee_manager"
                              confirm="Program will generate the fees data in accounting, confirm?" icon="fa-exchange fa-2x"/>

                      <button name="fees_extract_api_button" string="Estrai corrispettivi API" type="object" class="btn-primary" colspan="1"
                              groups="tyres_logistic_management.group_logistic_fee_manager"
                              confirm="Il programma generera i corrispettivi tramite chiamata API, confermi?" icon="fa-exchange fa-2x"/>
                  </header>
                  <sheet>
                      <group colspan="4" col="4">
                          <separator string="Report: Accounting Fees" colspan="4"/>
                          <field name="evaluation_date" />
                          <field name="team_id" />
                      </group>
                  </sheet>
              </form>
            </field>
        </record>

        <record id="action_logistic_fees_extract_wizard" model="ir.actions.act_window">
            <field name="name">Fees operations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">logistic.fees.extract.wizard</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_logistic_fees_extract_wizard"/>
            <field name="target">new</field>
        </record>

         <menuitem
             id="menu_logistic_management_fees_root"
             parent="menu_logistic_header_root"
             name="Fees"
             sequence="51"
             groups="tyres_logistic_management.group_logistic_sale_manager,tyres_logistic_management.group_logistic_manager"
             />
             <menuitem
                 parent="menu_logistic_management_fees_root"
                 id="menu_logistic_management_fees_extract"
                 sequence="10"
                 action="action_logistic_fees_extract_wizard"
                 />
             <menuitem
                 parent="crm.menu_logistic_management_fees_root"
                 id="menu_logistic_management_fees_api"
                 name="Scontrini"
                 action="action_logistic_fees_api"
                 sequence="20"/>
    </data>
</openerp>

