<?xml version="1.0"?>
<odoo>
    <data>
        <!-- Fees API header -->
        <record id="view_logistic_fees_api_tree" model="ir.ui.view">
            <field name="name">logistic.fees.api.tree</field>
            <field name="model">logistic.fees.api</field>
            <field name="arch" type="xml">
                <tree string="Documenti API Fees" decoration-success="state == 'done'" decoration-danger="error == True">
                    <field name="team_id" />
                    <field name="payment_term_id" />
                    <field name="payment_code" />
                    <field name="account_ref" />
                    <field name="account_date" />
                    <field name="odoo_total" sum="odoo"/>
                    <field name="account_total" sum="account"/>
                    <field name="error" invisible="1"/>
                    <field name="direct_fee" />
                    <field name="state" />
                    <button name="api_sync" type="object" string="API Sync" confirm="Confermi chiamata API con gestionale?" attrs="{'invisible': [('state', '=', 'done')]}"/>
                </tree>
            </field>
        </record>
        <record id="view_logistic_fees_api_form" model="ir.ui.view">
            <field name="name">logistic.fees.api.form</field>
            <field name="model">logistic.fees.api</field>
            <field name="arch" type="xml">
                <form string="Documento API Fees">
                    <header>
                        <button name="api_sync" type="object" string="API Sync" confirm="Confermi chiamata API con gestionale?" attrs="{'invisible': [('state', '=', 'done')]}"/>
                        <button name="wfk_manual" type="object" string="Porta in Manuale" confirm="Attenzione, passare a stato nanuale vuol dire sbloccare la parte dello scontrino per compilare a mano i valori, Confermi?"
                                attrs="{'invisible': [('state', '=', 'manual')]}"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done,manual"/>
                    </header>
                    <sheet>
                        <div class="alert alert-danger text-center o_form_header" role="status" attrs="{'invisible': [('error', '=', False)]}">
                            <strong>Attenzione!</strong> Si è verificato un errore durante la sincronizzazione o il controllo delle date extra.
                        </div>

                        <group>
                            <group string="Risposta gestionale">
                                <field name="account_ref" placeholder="Rif. scontrino" attrs="{'readonly': [('state', '!=', 'manual')]}"/>
                                <field name="account_date" attrs="{'readonly': [('state', '!=', 'manual')]}"/>
                            </group>
                            <group string="Totali">
                                <field name="odoo_total" attrs="{'readonly': [('state', '!=', 'manual')]}"/>
                                <field name="account_total" attrs="{'readonly': [('state', '!=', 'manual')]}"/>
                                <field name="direct_fee" readonly="1" />
                            </group>
                        </group>
                        <notebook colspan="4">
                            <page string="Dettaglio" name="page_detail">
                                <group>
                                    <group string="Dati Principali">
                                        <field name="date" readonly="1"/>
                                        <field name="team_id" readonly="1"/>
                                        <field name="payment_term_id" readonly="1"/>
                                        <field name="payment_code" readonly="1"/>
                                    </group>
                                    <group string="Stato e Sincronizzazione">
                                        <field name="force_account_ref" readonly="1"/>
                                        <field name="error" readonly="1" widget="boolean_toggle"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Picking" name="page_note">
                                <group string="Picking collegati">
                                    <field name="picking_ids" readonly="1" nolabel="1"/>
                                </group>
                            </page>
                            <page string="Movimenti" name="page_note">
                                <group string="Movimenti collegati">
                                    <field name="move_ids" readonly="1" nolabel="1"/>
                                </group>
                            </page>
                            <page string="Note e Controlli" name="page_note">
                                <group>
                                    <field name="extra_date" readonly="1"/>
                                </group>
                            </page>
                            <page string="Risposta JSON" name="page_json" attrs="{'invisible': [('json_reply', '=', False)]}">
                                <group>
                                    <field name="json_reply" readonly="1" />
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_logistic_fees_api_search" model="ir.ui.view">
            <field name="name">logistic.fees.api.search</field>
            <field name="model">logistic.fees.api</field>
            <field name="arch" type="xml">
                <search string="Ricerca Scontrini">
                    <field name="account_date" string="Data passaggio"/>
                    <field name="account_ref" string="Riferimento scontrino"/>

                    <field name="team_id" string="Canale di Vendita"/>
                    <field name="payment_term_id" string="Canale di Vendita"/>
                    <field name="payment_code" string="Codice Pagamento"/>
                    <field name="date" string="Data creazione" />

                    <filter string="Oggi" name="filter_today" domain="[('account_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                    <separator/>

                    <filter string="Da Sincronizzare" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Sincronizzati" name="filter_done" domain="[('state', '=', 'done')]"/>
                    <separator/>

                    <filter string="Diretti" name="filter_direct_fee" domain="[('direct_fee', '=', True)]"/>
                    <filter string="Automatici" name="filter_automatic_fee" domain="[('direct_fee', '=', False)]"/>
                    <separator/>

                    <filter string="Con Errore" name="filter_error" domain="[('error', '=', True)]"/>
                    <filter string="Da inviare" name="filter_not_sent" domain="[('state', '!=', 'done')]"/>

                    <group expand="0" string="Raggruppa per">
                        <filter string="Canale" name="group_by_team" context="{'group_by': 'team_id'}"/>
                        <filter string="Pagamento" name="group_by_payment" context="{'group_by': 'payment_term_id'}"/>
                        <filter string="Data ins. - Giorno" name="group_by_date" context="{'group_by': 'account_date:day'}"/>
                        <filter string="Data ins. - Mese" name="group_by_date" context="{'group_by': 'account_date:month'}"/>
                        <filter string="Modalità" name="group_direct_fee" context="{'group_by': 'direct_fee'}"/>
                        <filter string="Stato" name="group_by_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record id="action_logistic_fees_api" model="ir.actions.act_window">
            <field name="name">Documenti API Fees</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">logistic.fees.api</field>
            <field name="view_type">form</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_logistic_fees_api_search"/>
            <field name="context">{'search_default_filter_today': True}</field>
        </record>
        <record id="ir_pending_fees_order_server_action" model="ir.actions.server">
            <field name="name">Ordini da scontrino</field>
            <field name="type">ir.actions.server</field>
            <field name="model_id" ref="sale.model_sale_order" />
            <field name="binding_model_id" ref="sale.model_sale_order" />
            <field name="state">code</field>
            <field name="code">
                action = env['sale.order'].pending_fees_order()
            </field>
        </record>

        <!-- WIZARD -->
        <record id="view_logistic_fees_extract_wizard" model="ir.ui.view">
            <field name="name">Fees extract wizard</field>
            <field name="model">logistic.fees.extract.wizard</field>
            <field name="arch" type="xml">
              <form string="Logistic operation management:">
                  <header>
                      <button string="Cancel" class="btn-default" special="cancel" />

                      <button name="fees_report_button" string="Print report" type="object" colspan="1" icon="fa-file-text-o fa-2x"/>
                      <button name="fees_report_button_v2" string="Stampa (v.2)" type="object" class="btn-primary" colspan="1" icon="fa-file-text-o fa-2x"/>

                      <button name="fees_extract_button" string="Extract fees" type="object" colspan="1"
                              groups="tyres_logistic_management.group_logistic_fee_manager"
                              confirm="Program will generate the fees data in accounting, confirm?" icon="fa-exchange fa-2x"/>
                      <button name="fees_extract_api_button" string="Estrai corrispettivi API" type="object" class="btn-primary" colspan="1"
                              groups="tyres_logistic_management.group_logistic_fee_manager"
                              confirm="Il programma generera i corrispettivi tramite chiamata API, confermi?" icon="fa-exchange fa-2x"/>
                  </header>
                  <sheet>
                      <group colspan="4" col="4">
                          <separator string="Report: Accounting Fees" colspan="4"/>
                          <field name="evaluation_date" />
                          <field name="team_id" />
                      </group>
                  </sheet>
              </form>
            </field>
        </record>

        <record id="action_logistic_fees_extract_wizard" model="ir.actions.act_window">
            <field name="name">Fees operations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">logistic.fees.extract.wizard</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_logistic_fees_extract_wizard"/>
            <field name="target">new</field>
        </record>

         <menuitem
             id="menu_logistic_management_fees_root"
             parent="menu_logistic_header_root"
             name="Fees"
             sequence="51"
             groups="tyres_logistic_management.group_logistic_sale_manager,tyres_logistic_management.group_logistic_manager"
             />
             <menuitem
                 parent="menu_logistic_management_fees_root"
                 id="menu_logistic_management_fees_extract"
                 sequence="10"
                 action="action_logistic_fees_extract_wizard"
                 />
             <menuitem
                 parent="menu_logistic_management_fees_root"
                 id="menu_logistic_management_order_for_fees_api"
                 name="Ordini da Scontrino"
                 action="ir_pending_fees_order_server_action"
                 sequence="20"/>
             <menuitem
                 parent="menu_logistic_management_fees_root"
                 id="menu_logistic_management_fees_api"
                 name="Scontrini fatti"
                 action="action_logistic_fees_api"
                 sequence="30"/>
    </data>
</odoo>
